# Supabase project credentials (Project Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional fallback only for older Supabase projects that still use the legacy anon key.
# Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new projects.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL used for metadata, canonical URLs, and share links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production example:
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
