NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required when calling POST /api/webhooks/social-share from Vercel Cron or another scheduler.
SOCIAL_SHARE_WEBHOOK_SECRET=change-this-secret

# Optional. Used by Facebook Page and Instagram Graph API sender adapters.
SOCIAL_SHARE_META_GRAPH_VERSION=v22.0

# LinkedIn OAuth. Put these in .env.local and Vercel Environment Variables, never in browser code.
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-primary-client-secret
# Optional. If empty, the app uses NEXT_PUBLIC_SITE_URL + /api/auth/linkedin/callback
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback
